{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/find_doc_reminder.py",
            "comment": "搜 doc/ 时提醒优先用 /find-doc skill（省 50-70% token）+ 记录调用统计到 .runtime/find-doc-stats.log"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/version_check.py",
            "comment": "git commit 前强制版本号 bump 检查（workflow.md §9 红线）：staged 未含版本号文件则 exit 2 阻断。非 commit 命令立即放行。"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/memory_lint.py",
            "comment": "memory 文件改动后校验 MEMORY.md 行数（≤200）+ 孤儿/死链接"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/rule_index_check.py",
            "comment": "rule 文件改动后校验 CLAUDE.md §2 索引 ↔ rules/*.md 一致性"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/rule_size_check.py",
            "comment": "rule 文件改动后检查大小红线（详见 templates/rules/meta_rule_design.md §5）"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/session_snapshot.py post-compact",
            "comment": "compact 自动存档 — 防止压缩后细节丢失。详见 /snapshot skill 描述。"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/session_snapshot.py stop",
            "comment": "每轮停止时自动存档（5min 节流，类似 Word 自动保存）。详见 /snapshot skill 描述。"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/show_state.py prompt-state",
            "comment": "每次 prompt 前注入仓库状态（branch / dirty / ahead-behind / version）到 Claude 上下文"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/context_warning.py",
            "comment": "上下文预算预警 — 跨 75%/85%/95% 阈值时输出 [ctx-budget] 信号给 Claude (详见 CLAUDE.md §10)。slash command 自动豁免不死锁。"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/show_state.py session-start",
            "comment": "session 开始时注入仓库状态 + snapshot 接续提示 + 归档候选数"
          }
        ]
      }
    ]
  }
}
