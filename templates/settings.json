{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git ls-files:*)",
      "Bash(git shortlog:*)",
      "Bash(git reflog:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(env)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(maturin:*)",
      "Bash(tsc:*)",
      "Bash(dotnet:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-Location)",
      "PowerShell(Select-String:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Get-Command:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Resolve-Path:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git merge:*)",
      "Bash(git cherry-pick:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p12)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./.npmrc)",
      "Read(./.pypirc)",
      "Read(./.git-credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Bash(cat .env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --delete:*)",
      "Bash(git push -d:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag --delete:*)",
      "Bash(git reflog expire:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git stash clear:*)",
      "Bash(git stash drop:*)",
      "Bash(git update-ref -d:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shred:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(Clear-Content:*)",
      "PowerShell(Clear-Disk:*)",
      "PowerShell(Format-Volume:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git clean:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",
      "Bash(gh release create:*)",
      "Bash(docker push:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "PowerShell(Stop-Computer:*)",
      "PowerShell(Restart-Computer:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/find_doc_reminder.py",
            "comment": "搜 doc/ 时提醒优先用 /find-doc skill（省 50-70% token）+ 记录调用统计到 .runtime/find-doc-stats.log"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/version_check.py",
            "comment": "git commit 前强制版本号 bump 检查（workflow.md §9 红线）：staged 未含版本号文件则 exit 2 阻断。非 commit 命令立即放行。"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/memory_lint.py",
            "comment": "memory 文件改动后校验 MEMORY.md 行数（≤200）+ 孤儿/死链接"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/rule_index_check.py",
            "comment": "rule 文件改动后校验 CLAUDE.md §2 索引 ↔ rules/*.md 一致性"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/rule_size_check.py",
            "comment": "rule 文件改动后检查大小红线（详见 templates/rules/meta_rule_design.md §5）"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/session_snapshot.py post-compact",
            "comment": "compact 自动存档 — 防止压缩后细节丢失。详见 /snapshot skill 描述。"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/session_snapshot.py stop",
            "comment": "每轮停止时自动存档（5min 节流，类似 Word 自动保存）。详见 /snapshot skill 描述。"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/show_state.py prompt-state",
            "comment": "每次 prompt 前注入仓库状态（branch / dirty / ahead-behind / version）到 Claude 上下文"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/context_warning.py",
            "comment": "上下文预算预警 — 跨 75%/85%/95% 阈值时输出 [ctx-budget] 信号给 Claude (详见 CLAUDE.md §10)。slash command 自动豁免不死锁。"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/hooks/show_state.py session-start",
            "comment": "session 开始时注入仓库状态 + snapshot 接续提示 + 归档候选数"
          }
        ]
      }
    ]
  }
}
