#!/bin/sh
# bridgeforge pre-commit 闸（多段，严格执行序；详见 docs/harness-engineering-design.md §2.1）:
#   [D8] dogfood 镜像闸: templates/codex/hooks/*.py 缺 .codex/hooks/ 对应 → exit 2; 正文差异只 stderr 软提示
#   [D6] 规则闸: rule_size 读 staged blob + rule_index 读工作树 → 违规 exit 2
#   [model] Codex 模型/effort 路由闸: config.toml 与 .codex/agents/*.toml 漂移 → exit 2
#   [skills] 通用 skill metadata 闸: skills/<name>/SKILL.md 缺可调用 frontmatter → exit 2
#   [既有] memory 索引重建: 提交前重建衍生索引(_stats.json/MEMORY.md/MEMORY_COLD.md)并纳入本次提交
#          —— 卫生段，永 exit 0 兜底。杜绝"花名册欠账"溜过任意提交路径(git-sync/手动/IDE 都拦得住)。
#
# 硬闸原则: 只有明确判出违规才 exit 2; 脚本自身异常一律放行(宁漏不误伤)。
#   · exit 2 段必须置于末行 exit 0 之前，否则被吞(硬伤2)。镜像闸置最前。
#   · 规则闸豁免走 CHANGELOG.md 顶部 [skip-rule-size]; 镜像闸豁免走 [dogfood-exempt: <hook> <因>]。
#     (pre-commit 在 commit message 生成前触发，读不到 message，故豁免走已 staged 的 CHANGELOG 顶部)。
# python 自动探测: 下游优先 .venv, bridgeforge 自身回退系统 python → 两层脚本逐字一致。
find_py() {
  for PY in .venv/Scripts/python.exe .venv/bin/python python3 python; do
    if { [ -x "$PY" ] || command -v "$PY" >/dev/null 2>&1; } && "$PY" -c "" >/dev/null 2>&1; then
      echo "$PY"; return 0
    fi
  done
  return 1
}
PY="$(find_py)"

# ── [D8] dogfood 镜像闸(缺文件硬拦 exit 2; 正文差异只 stderr 软提示不阻断) ──
if [ -n "$PY" ] && [ -f ".codex/hooks/mirror_drift_check.py" ]; then
  "$PY" .codex/hooks/mirror_drift_check.py
  rc=$?
  [ "$rc" = 2 ] && exit 2
fi

# [encoding] UTF-8 BOM is forbidden in BridgeForge text surfaces.
if [ -n "$PY" ] && [ -f ".codex/hooks/encoding_check.py" ]; then
  "$PY" .codex/hooks/encoding_check.py --pre-commit
  rc=$?
  [ "$rc" = 2 ] && exit 2
fi

# ── [D6] 规则闸(硬拦; 无 python 或脚本缺失则跳过, 不阻断) ──
if [ -n "$PY" ]; then
  if [ -f ".codex/hooks/rule_size_check.py" ]; then
    "$PY" .codex/hooks/rule_size_check.py --pre-commit
    rc=$?
    [ "$rc" = 2 ] && exit 2
  fi
  if [ -f ".codex/hooks/rule_index_check.py" ]; then
    "$PY" .codex/hooks/rule_index_check.py --pre-commit
    rc=$?
    [ "$rc" = 2 ] && exit 2
  fi
fi

# ── [model] Codex 模型/effort 路由闸(硬拦; 无 python 或脚本缺失则跳过, 不阻断) ──
if [ -n "$PY" ] && [ -f ".codex/hooks/model_policy_check.py" ]; then
  "$PY" .codex/hooks/model_policy_check.py --pre-commit
  rc=$?
  [ "$rc" = 2 ] && exit 2
fi

# ── [skills] 通用 skill metadata 闸(硬拦; 下游无 skills/ 则自门控 no-op) ──
if [ -n "$PY" ] && [ -f ".codex/hooks/skill_metadata_check.py" ]; then
  "$PY" .codex/hooks/skill_metadata_check.py --pre-commit
  rc=$?
  [ "$rc" = 2 ] && exit 2
fi

# ── [既有] memory 索引重建(卫生段, 永 exit 0 兜底) ──
SCRIPT=".codex/scripts/memory_rebuild_index.py"
if [ -n "$PY" ] && [ -f "$SCRIPT" ]; then
  "$PY" "$SCRIPT" || true
  git add .codex/memory/_stats.json .codex/memory/MEMORY.md .codex/memory/MEMORY_COLD.md 2>/dev/null || true
fi
exit 0
