{
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git ls-files:*)",
      "Bash(git shortlog:*)",
      "Bash(git reflog:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(env)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(maturin:*)",
      "Bash(tsc:*)",
      "Bash(dotnet:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-Location)",
      "PowerShell(Select-String:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Get-Command:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Resolve-Path:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git merge:*)",
      "Bash(git cherry-pick:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p12)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./.npmrc)",
      "Read(./.pypirc)",
      "Read(./.git-credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Bash(cat .env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --delete:*)",
      "Bash(git push -d:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag --delete:*)",
      "Bash(git reflog expire:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git stash clear:*)",
      "Bash(git stash drop:*)",
      "Bash(git update-ref -d:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shred:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(Clear-Content:*)",
      "PowerShell(Clear-Disk:*)",
      "PowerShell(Format-Volume:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git clean:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",
      "Bash(gh release create:*)",
      "Bash(docker push:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "PowerShell(Stop-Computer:*)",
      "PowerShell(Restart-Computer:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/version_check.py",
            "comment": "git commit 前强制版本号 bump 检查（workflow.md §9）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己也受此约束。"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/allow_memory_write.py",
            "comment": "放行 memory .md 写入免弹窗（.claude/ 受保护目录连带挡住 memory）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己存记忆也免弹窗。改完须开新会话生效。"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/context_warning.py",
            "comment": "上下文预算预警 — 跨 75%/85%/95% 阈值输出 [ctx-budget] 信号（CLAUDE.md §10）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己也享同款预警。"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/clarify_reminder.py",
            "comment": "较大需求澄清提醒：便宜负向 gate（slash/极短/续接跳过）后注入 [clarify] 便利贴，模型精判是否真需澄清。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自身开发也享 clarify 防冲动动手。"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/focus_reminder.py",
            "comment": "任务防漂移 focus 锚：记第一条实质 prompt 为任务锚，之后每 FOCUS_EVERY 轮注入 [focus] 提醒拉回主线。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自身开发也享同款防漂移（dogfood）。"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/memory_access_tracker.py",
            "comment": "memory 访问追踪：Claude 读 .claude/memory/*.md 时，把今天日期写入 _stats.json（唯一日期去重）。Stop hook 重建 MEMORY.md 热区时用此数据计算艾宾浩斯衰减分。dev 仓库无 .venv，用系统 python。"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/rule_size_check.py",
            "comment": "rule 文件改动后检查大小红线 + 触发器宽度（详见 templates/rules/meta_rule_design.md §5）。dev 仓库无 .venv，用系统 python。自产自用：本仓库编辑 .claude/rules 时受同款量化红线约束。"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/requirements_check.py",
            "comment": "requirements*.txt 改动后校验可移植性红线：绝对路径 URL（@ file://）+ 非 ASCII 字符（Windows pip GBK 解码会报错）。详见 rules/portability.md §4.1/§4.2。dev 仓库无 .venv，用系统 python。自门控：非 requirements*.txt 静默 no-op —— setup_agent 无 requirements.txt，挂着正是验证「自门控 no-op」产品承诺。"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_snapshot.py post-compact",
            "comment": "compact 自动存档 — 防止压缩后细节丢失。dev 仓库无 .venv，用系统 python。"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_snapshot.py stop",
            "comment": "每轮停止时自动存档 + 重建 MEMORY.md 热区/冷区（5min 节流）。dev 仓库无 .venv，用系统 python。"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/memory_junction_check.py",
            "comment": "memory junction 自愈：把 memory 纳入项目 git（.claude/memory/），系统路径 ~/.claude/projects/<hash>/memory/ 透明转发。每次 session 开始静默检查，不是 junction 则恢复（新机 clone 自动建链）。绝不硬删数据（首迁用 rename-to-.bak 兜底）。详见 rules/portability.md §2.1。dev 仓库无 .venv，用系统 python。"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/target_cleanup.py",
            "comment": "仅 Rust 项目生效：incremental/ 缓存超 30GB 后台清理。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 非 Rust 项目，此处永远自门控 no-op —— 挂着正是为了验证「无 Cargo.toml 静默跳过」这条产品承诺。"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/skill_sync_check.py",
            "comment": "用户级通用 skill 漂移自检（支柱 B / 开机自检）：比对 ~/.claude/skills/ 副本与上游源，缺失/不一致则提示跑 /setup_agent。只读不改。dev 仓库无 .venv，用系统 python。自产自用：本机上游是 junction→开发仓库，正好检测「改了 skills/ 源但没同步用户级副本」的开发期漂移。"
          }
        ]
      }
    ]
  }
}
