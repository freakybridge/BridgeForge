{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git ls-files:*)",
      "Bash(git shortlog:*)",
      "Bash(git reflog:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(env)",
      "Bash(date)",
      "Bash(whoami)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(maturin:*)",
      "Bash(tsc:*)",
      "Bash(dotnet:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-Location)",
      "PowerShell(Select-String:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Get-Command:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Resolve-Path:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git merge:*)",
      "Bash(git cherry-pick:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p12)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./.npmrc)",
      "Read(./.pypirc)",
      "Read(./.git-credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Bash(cat .env*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --delete:*)",
      "Bash(git push -d:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag --delete:*)",
      "Bash(git reflog expire:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git stash clear:*)",
      "Bash(git stash drop:*)",
      "Bash(git update-ref -d:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shred:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(Clear-Content:*)",
      "PowerShell(Clear-Disk:*)",
      "PowerShell(Format-Volume:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git clean:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",
      "Bash(gh release create:*)",
      "Bash(docker push:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "PowerShell(Stop-Computer:*)",
      "PowerShell(Restart-Computer:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/version_check.py",
            "comment": "git commit 前强制版本号 bump 检查（workflow.md §9）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己也受此约束。"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/allow_memory_write.py",
            "comment": "放行 memory .md 写入免弹窗（.claude/ 受保护目录连带挡住 memory）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己存记忆也免弹窗。改完须开新会话生效。"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/context_warning.py",
            "comment": "上下文预算预警 — 跨 75%/85%/95% 阈值输出 [ctx-budget] 信号（CLAUDE.md §10）。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 自己也享同款预警。"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/target_cleanup.py",
            "comment": "仅 Rust 项目生效：incremental/ 缓存超 30GB 后台清理。dev 仓库无 .venv，用系统 python。自产自用：setup_agent 非 Rust 项目，此处永远自门控 no-op —— 挂着正是为了验证「无 Cargo.toml 静默跳过」这条产品承诺。"
          }
        ]
      }
    ]
  }
}
